ROCESO DESCUENTO
    ESCRIBIR "PROGRAMA QUE TE DESCUENTA EL 25%"
    ESCRIBIR "DIGITE SU NOMBRE "
    LEER NOMBRE
    ESCRIBIR " DIGITE SU SALARIO "
    LEER SALARIO 
    PORCENTAJE = SALARIO * 25 /100 // ESTA LINIEA CALCULA  EL PORCENTAJE
    SALARIOTOTAL = SALARIO - PORCENTAJE

    SI SALARIOTOTAL > 1000000000 ENTONCES 
    ESCRIBIR " SU SALARIO ES MUY ALTO, USTED GANA", SALARIOTOTAL
    SINO 
    ESCRIBIR " SU SALARIO ES MENOR A UN BILLON, USTED GANA ",SALARIOTOTAL
    FINSI 
    ESCRIBIR " SEÑOR ",  NOMBRE, " EL 25% DE SU SALARIO  DENEGADO ES ", SALARIO, " Y CON EL DESCUENTO DEL 25%, SU SALARIO QUEDA EN ", SALARIOTOTAL 
FINPROCESO

